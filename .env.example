# ── Admin CMS ──────────────────────────────────────────────────────────────
# Login credentials for the admin panel at /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# ── Contact form ───────────────────────────────────────────────────────────
# Your live domain — used for CSRF protection on the contact form
# Must match the origin the browser sends (no trailing slash)
ALLOWED_ORIGIN=https://adelaidepavilion.com.au

# MailerSend API key — from app.mailersend.com → API Tokens
# Leave blank to skip email sending (submissions will be logged only)
MAILERSEND_API_KEY=

# ── Bot protection (optional but recommended) ──────────────────────────────
# Cloudflare Turnstile secret key — from dash.cloudflare.com → Turnstile
# If blank, Turnstile verification is skipped (fine for local dev)
TURNSTILE_SECRET_KEY=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
